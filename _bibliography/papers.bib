@unpublished{Bodisz.2026,
  title={The DeFi Dilemma},
  author={Bodisz, Aron and Hautsch, Nikolaus and Voigt, Stefan},
  year={2026},
  abstract={Decentralized finance (DeFi) enables settlement without trusted intermediaries through two essential building blocks: pre-trade transparency of pending transactions and transaction-fee-based priority. We show that these features expose rent-generating transactions to front-running risk, deterring the transactions on which market efficiency depends. Using block-level data on cross-DEX arbitrage across Uniswap V2 and Sushiswap from December 2020 to November 2024, we find that between 89% and 99% of hypothetically profitable rents are left unrealized. Overcoming these inefficiencies is possible only by reinstalling central counterparties, thus undermining the fundamental principle of DeFi.},
  preview={front_running_visual.pdf},
  pdf={bodisz_defi_dilemma.pdf},
  selected={true}
}
